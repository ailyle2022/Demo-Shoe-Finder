# 前端项目环境变量配置
# 优先级：.env.local > .env.development/.env.production > .env

# 服务器端口配置（默认3000）
VITE_PORT=3000

# 应用标题
VITE_APP_TITLE=Demo Application

# API基础URL（Windows访问需要特殊配置）
VITE_API_BASE_URL=http://localhost:3001/api

# 开发模式配置
# localhost: 仅WSL内访问
# 0.0.0.0: 允许所有网络接口访问（包括Windows）
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_DEV_SERVER_OPEN=true

# 构建配置
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true